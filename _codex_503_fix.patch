+def normalize_service_tier(value: str) -> str:
+    tier = str(value or "").strip().lower()
+    return tier if tier in VALID_SERVICE_TIERS else ""
+
+
+def get_service_tiers() -> list[str]:
+    tiers = []
+    for tier in [GEMINI_SERVICE_TIER, GEMINI_SERVICE_TIER_FALLBACK]:
+        normalized = normalize_service_tier(tier)
+        if normalized and normalized not in tiers:
+            tiers.append(normalized)
+    return tiers or [""]
+
+
